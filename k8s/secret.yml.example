# Kubernetes Secret for sensitive configuration
# ==============================================
# ⚠️  IMPORTANT: Do NOT commit real secrets to version control!
#
# 1. Copy this file to secret.yml:
#      cp k8s/secret.yml.example k8s/secret.yml
#
# 2. Replace the placeholder values with your own secrets.
#    All values MUST be base64-encoded.
#    Generate strong secrets with:
#      openssl rand -base64 64    # for jwt_secret
#      openssl rand -hex 32       # for redis_password
#      echo -n "your-value" | base64  # for encoding any value
#
# 3. secret.yml is already in .gitignore — it will NOT be committed.
# ==============================================
apiVersion: v1
kind: Secret
metadata:
  name: webshelf-secrets
  namespace: webshelf
type: Opaque
data:
  # jwt_secret - JWT token signing secret (64 bytes Base64-encoded)
  # Generate: openssl rand -base64 64 | base64
  jwt_secret: <base64-encoded-jwt-secret>

  # database_url - Complete PostgreSQL connection URL (base64-encoded)
  #
  # With CloudNativePG (RW service → primary):
  #   postgres://postgres:<PASSWORD>@webshelf-db-rw.webshelf.svc.cluster.local:5432/webshelf
  #
  # Without CNP (standalone single-instance):
  #   postgres://postgres:<PASSWORD>@postgres-service.webshelf.svc.cluster.local:5432/webshelf
  #
  # Generate: echo -n "postgres://postgres:your-password@webshelf-db-rw.webshelf.svc.cluster.local:5432/webshelf" | base64
  database_url: <base64-encoded-database-url>

  # database_read_urls - Read replica connection URL(s) (base64-encoded)
  #
  # With CloudNativePG — CNP's .ro service load-balances across all
  # replicas, so only ONE URL is needed:
  #   postgres://postgres:<PASSWORD>@webshelf-db-ro.webshelf.svc.cluster.local:5432/webshelf
  #
  # Without CNP (standalone single-instance): leave EMPTY for
  # single-database mode (AutoRouter degrades to pass-through).
  #   Generate: echo -n "" | base64   (output is empty, leave value blank)
  #
  # Generate:
  #   echo -n "postgres://postgres:your-password@webshelf-db-ro.webshelf.svc.cluster.local:5432/webshelf" | base64
  database_read_urls: <your-base64-encoded-read-url-or-leave-empty>

  # postgres_password - PostgreSQL authentication password (base64-encoded)
  # Generate: echo -n "your-strong-password" | base64
  postgres_password: <base64-encoded-postgres-password>

  # redis_password - Redis authentication password (hex-only, 32 chars, then base64-encoded)
  # Generate: echo -n "$(openssl rand -hex 32)" | base64
  # Tip: Use hex-only passwords to avoid URL encoding issues
  redis_password: <base64-encoded-redis-password>

  # redis_url - Complete Redis connection URL (base64-encoded)
  # Format: redis://:<PASSWORD>@redis-service.webshelf.svc.cluster.local:6379
  # Generate: echo -n "redis://:your-password@redis-service.webshelf.svc.cluster.local:6379" | base64
  redis_url: <base64-encoded-redis-url>

  # system_admin_email - System admin login email (base64-encoded)
  # Generate: echo -n "admin@example.com" | base64
  system_admin_email: <base64-encoded-system-admin-email>

  # system_admin_password - System admin login password (base64-encoded)
  # Generate: echo -n "your-strong-admin-password" | base64
  system_admin_password: <base64-encoded-system-admin-password>
---
# ==========================================
# CloudNativePG Init Secret
# ==========================================
# Used by CNP's bootstrap.initdb.secret to set the initial postgres
# superuser password. The password MUST match the one embedded in
# database_url and database_read_urls above.
#
# CNP will create a Secret named <cluster-name>-superuser
# (e.g., webshelf-db-superuser) with the following keys:
#   username, password, dbname, host, port, pgpass, uri, jdbc-uri
# The password in that Secret will match this one.
# ==========================================
apiVersion: v1
kind: Secret
metadata:
  name: webshelf-db-init-secret
  namespace: webshelf
type: kubernetes.io/basic-auth
stringData:
  username: postgres
  password: <your-strong-postgres-password>
