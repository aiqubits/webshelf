# ==============================================
# WebShelf Shared Configuration File
# ==============================================
# Copy this file to config.toml and update values for your environment
# This configuration is shared between server and frontend (app)

# Database connection URL (PostgreSQL)
# Replace CHANGE_ME_POSTGRES_PASSWORD with a strong password
# Format: postgres://user:password@host:port/database
# Can be overridden by environment variable: WEBSHELF_DATABASE_URL
database_url = "postgres://postgres:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/webshelf"

# Redis connection URL (for distributed locking only)
# NOTE: When using Docker Compose, this is overridden by WEBSHELF_REDIS_URL
#       which includes the Redis password. Make sure to include the password
#       if your Redis instance has requirepass enabled.
# ⚠️  Use percent-encoding for special characters in the password
#     (e.g., p%40ss for p@ss, p%2Fss for p/ss).
#     To avoid this, generate passwords with: openssl rand -hex 32
# Format: redis://[:password]@host:port
# Can be overridden by environment variable: WEBSHELF_REDIS_URL
redis_url = "redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379"

# ⚠️  SECURITY WARNING: MUST change this in production!
# Generate a strong secret with: openssl rand -base64 64
# The server will refuse to start with this placeholder in non-development mode.
# Can be overridden by environment variable: WEBSHELF_JWT_SECRET
jwt_secret = "REPLACE_ME_WITH_A_STRONG_SECRET"

# JWT token expiration time in seconds (default: 1 hour)
# Can be overridden by environment variable: WEBSHELF_JWT_EXPIRY_SECONDS
jwt_expiry_seconds = 3600

# System admin account (auto-seeded on first boot, only one can exist)
# The system admin has super-admin privileges (bypasses all admin-only restrictions)
# ⚠️  SECURITY: MUST override these in staging/production environments!
#     The server will refuse to start with default values in non-development mode.
# Can be overridden by environment variables: WEBSHELF_SYSTEM_ADMIN_EMAIL / WEBSHELF_SYSTEM_ADMIN_PASSWORD
system_admin_email = "admin@webshelf.local"
system_admin_password = "change-me-admin-password"

# Server configuration
[server]
# Server bind address
# Can be overridden by environment variable: WEBSHELF_SERVER__HOST
host = "0.0.0.0"
# Server port
# Can be overridden by environment variable: WEBSHELF_SERVER__PORT
port = 3000
# Allowed CORS origins (REQUIRED for staging/production environments)
# In non-development mode, the server will log an error and block all
# cross-origin requests if this list is empty.
# Can be overridden by environment variable: WEBSHELF_SERVER__ALLOWED_ORIGINS
#   Environment variable format: comma-separated list
#   Example: export WEBSHELF_SERVER__ALLOWED_ORIGINS="https://example.com,https://app.example.com"
# allowed_origins = ["https://example.com", "https://app.example.com"]

# Database connection pool configuration
[database]
# Maximum number of connections in the pool
# Can be overridden by environment variable: WEBSHELF_DATABASE__MAX_CONNECTIONS
max_connections = 10
# Minimum number of idle connections to maintain
# Can be overridden by environment variable: WEBSHELF_DATABASE__MIN_CONNECTIONS
min_connections = 1

# Email (SMTP) configuration
# When left empty / default, the email service is disabled and registration
# auto-verifies users (useful for development). Configure all fields below to
# enable sending verification and welcome emails.
[email]
# SMTP server hostname
smtp_host = ""
# SMTP port (587 for STARTTLS, 465 for implicit TLS, 25 for plain)
smtp_port = 587
# SMTP authentication username
smtp_username = ""
# SMTP authentication password
smtp_password = ""
# From address for outgoing emails
from_address = ""
# Optional display name for the from address
from_name = "Webshelf"
# Whether to use TLS (STARTTLS or implicit TLS depending on port)
use_tls = true
# Connection timeout in seconds (0 = no timeout)
timeout_secs = 30
