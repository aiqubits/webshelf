# ==============================================
# WebShelf Environment Configuration
# ==============================================
# Copy this file to .env and update values for your environment
# This file is shared between server and web (frontend)

# ----------------------------------------------
# Server Configuration
# ----------------------------------------------

# Database connection URL (PostgreSQL)
# Replace CHANGE_ME_POSTGRES_PASSWORD with a strong password
WEBSHELF_DATABASE_URL=postgres://postgres:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/webshelf

# Read replica database URLs (comma-separated, empty = disabled)
# When configured, SELECT queries are automatically routed to read replicas.
# Format: postgres://user:password@host:port/database
# Example: WEBSHELF_DATABASE_READ_URLS="postgres://postgres:password@replica1:5432/webshelf,postgres://postgres:password@replica2:5432/webshelf"
# Can be overridden in config.toml: database_read_urls
WEBSHELF_DATABASE_READ_URLS=

# Database pool timeout configuration (optional, have defaults)
# Connection timeout in seconds (default: 8)
# Can be overridden in config.toml: database.connect_timeout_secs
# WEBSHELF_DATABASE__CONNECT_TIMEOUT_SECS=8
# Idle timeout in seconds (default: 600)
# Can be overridden in config.toml: database.idle_timeout_secs
# WEBSHELF_DATABASE__IDLE_TIMEOUT_SECS=600
# Acquire timeout in seconds (default: 30)
# Can be overridden in config.toml: database.acquire_timeout_secs
# WEBSHELF_DATABASE__ACQUIRE_TIMEOUT_SECS=30

# Read replica pool timeout configuration (optional, independent from write pool)
# Connection timeout in seconds (default: 5)
# Can be overridden in config.toml: database_read.connect_timeout_secs
# WEBSHELF_DATABASE_READ__CONNECT_TIMEOUT_SECS=5
# Idle timeout in seconds (default: 600)
# Can be overridden in config.toml: database_read.idle_timeout_secs
# WEBSHELF_DATABASE_READ__IDLE_TIMEOUT_SECS=600
# Acquire timeout in seconds (default: 10)
# Can be overridden in config.toml: database_read.acquire_timeout_secs
# WEBSHELF_DATABASE_READ__ACQUIRE_TIMEOUT_SECS=10

# PostgreSQL password (Docker Compose: passed to postgres container)
WEBSHELF_POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Redis connection URL (for distributed locking, optional)
# Include password if requirepass is enabled: redis://:password@host:port
WEBSHELF_REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379

# Redis password (Docker Compose: passed to redis container)
WEBSHELF_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Application environment (development, staging, production)
# Non-development environments require a strong JWT secret (≥32 characters)
WEBSHELF_ENV=development

# JWT secret key (CHANGE THIS IN PRODUCTION!)
# Generate with: openssl rand -base64 64
# Required when WEBSHELF_ENV is not "development"
WEBSHELF_JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET

# JWT token expiration time in seconds (default: 3600 = 1 hour)
# Can be overridden in config.toml: jwt_expiry_seconds
WEBSHELF_JWT_EXPIRY_SECONDS=3600

# JWT expiration when "remember me" is enabled (default: 2592000 = 30 days)
# Can be overridden in config.toml: jwt_remember_expiry_seconds
WEBSHELF_JWT_REMEMBER_EXPIRY_SECONDS=2592000

# Refresh token expiration time in seconds (default: 7776000 = 90 days)
# Refresh tokens are used for silent JWT renewal when the JWT expires.
# Can be overridden in config.toml: refresh_token_expiry_seconds
WEBSHELF_REFRESH_TOKEN_EXPIRY_SECONDS=7776000

# Whether to set the Secure flag on auth cookies (default: true)
# Set to false for local development over plain HTTP.
# MUST be true in production (requires HTTPS).
# Can be overridden in config.toml: cookie_secure
WEBSHELF_COOKIE_SECURE=true

# System admin account (auto-seeded on first boot, only one can exist)
# The system admin has super-admin privileges (bypasses all admin-only restrictions)
# ⚠️  SECURITY: MUST override these in staging/production environments!
#     The server will refuse to start with default values in non-development mode.
WEBSHELF_SYSTEM_ADMIN_EMAIL=admin@webshelf.local
WEBSHELF_SYSTEM_ADMIN_PASSWORD=change-me-admin-password

# Server bind address
WEBSHELF_SERVER__HOST=0.0.0.0
WEBSHELF_SERVER__PORT=3000

# Log level (trace, debug, info, warn, error)
RUST_LOG=info

# ----------------------------------------------
# Email (SMTP) Configuration
# ----------------------------------------------
# When left empty / default, the email service is disabled and registration
# auto-verifies users (useful for development). Configure all fields below to
# enable sending verification and welcome emails.
#
# SMTP server hostname
# WEBSHELF_EMAIL__SMTP_HOST=smtp.example.com
#
# SMTP port (587 for STARTTLS, 465 for implicit TLS, 25 for plain)
# WEBSHELF_EMAIL__SMTP_PORT=587
#
# SMTP authentication username
# WEBSHELF_EMAIL__SMTP_USERNAME=noreply@example.com
#
# SMTP authentication password
# WEBSHELF_EMAIL__SMTP_PASSWORD=your-smtp-password
#
# From address for outgoing emails
# WEBSHELF_EMAIL__FROM_ADDRESS=noreply@example.com
#
# Optional display name for the from address
# WEBSHELF_EMAIL__FROM_NAME=Webshelf
#
# Whether to use TLS (true=STARTTLS/implicit TLS, false=plain)
# WEBSHELF_EMAIL__USE_TLS=true
#
# Connection timeout in seconds (0 = no timeout)
# WEBSHELF_EMAIL__TIMEOUT_SECS=30

# ----------------------------------------------
# Frontend Configuration
# ----------------------------------------------

# The frontend is served via nginx which proxies /api/ to the backend.
# No separate API URL configuration is needed — nginx handles routing.
# See nginx/default.conf for the proxy configuration.
