# ==============================================
# WebShelf Environment Configuration
# ==============================================
# Copy this file to .env and update values for your environment
# This file is shared between server and web (frontend)

# ----------------------------------------------
# Server Configuration
# ----------------------------------------------

# Database connection URL (PostgreSQL)
# Replace CHANGE_ME_POSTGRES_PASSWORD with a strong password
WEBSHELF_DATABASE_URL=postgres://postgres:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/webshelf

# PostgreSQL password (Docker Compose: passed to postgres container)
WEBSHELF_POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Redis connection URL (for distributed locking, optional)
# Include password if requirepass is enabled: redis://:password@host:port
WEBSHELF_REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379

# Redis password (Docker Compose: passed to redis container)
WEBSHELF_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# Application environment (development, staging, production)
# Non-development environments require a strong JWT secret (≥32 characters)
WEBSHELF_ENV=development

# JWT secret key (CHANGE THIS IN PRODUCTION!)
# Generate with: openssl rand -base64 64
# Required when WEBSHELF_ENV is not "development"
WEBSHELF_JWT_SECRET=REPLACE_ME_WITH_A_STRONG_SECRET

# System admin account (auto-seeded on first boot, only one can exist)
# The system admin has super-admin privileges (bypasses all admin-only restrictions)
# ⚠️  SECURITY: MUST override these in staging/production environments!
#     The server will refuse to start with default values in non-development mode.
WEBSHELF_SYSTEM_ADMIN_EMAIL=admin@webshelf.local
WEBSHELF_SYSTEM_ADMIN_PASSWORD=change-me-admin-password

# Server bind address
WEBSHELF_SERVER__HOST=0.0.0.0
WEBSHELF_SERVER__PORT=3000

# Log level (trace, debug, info, warn, error)
RUST_LOG=info

# ----------------------------------------------
# Frontend Configuration
# ----------------------------------------------

# The frontend is served via nginx which proxies /api/ to the backend.
# No separate API URL configuration is needed — nginx handles routing.
# See nginx/default.conf for the proxy configuration.
